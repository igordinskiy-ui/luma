DOMAIN=app.example.com
POSTGRES_DB=kurilka
POSTGRES_USER=kurilka
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://kurilka:change-me@db:5432/kurilka
# For production, use a strong REDIS_PASSWORD and put its URL-encoded value in REDIS_URL.
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
SESSION_SECRET=replace-with-a-long-random-secret
APP_ENVIRONMENT=development
DEVELOPMENT_AUTH_ENABLED=false
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
PROXY_SHARED_SECRET=replace-with-a-long-random-proxy-secret
TELEGRAM_AUTH_MAX_AGE_SECONDS=900
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
TELEGRAM_OIDC_REDIRECT_URI=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@your-domain.example
CONTENT_REVIEW_STATUS=draft
# Exact SHA-256 shown by the content manifest after signed editorial review.
CONTENT_APPROVED_DIGEST=
# Exact API catalogue digest printed from apps/api by app.content.CONTENT_DIGEST.
CONTENT_CATALOGUE_DIGEST=
LEGAL_DOCUMENTS_STATUS=template
LEGAL_DOCUMENTS_VERSION=
# Exact digest printed by `python scripts/legal_manifest.py` after legal approval.
LEGAL_DOCUMENTS_DIGEST=
RISK_ENGINE_VERSION=rules_v1
ADMIN_TELEGRAM_IDS=
# Comma-separated allowlist of non-personal Telegram startapp campaign codes.
ACQUISITION_SOURCES=
# Active database retention windows. Legal review must approve production values.
OUTBOX_RETENTION_DAYS=30
DELIVERY_RETENTION_DAYS=90
ANALYTICS_RETENTION_DAYS=180
FEEDBACK_RETENTION_DAYS=365
